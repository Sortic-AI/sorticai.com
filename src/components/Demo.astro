---
---

<section class="demo section-padding" id="demo">
  <div class="container">
    <div class="demo__header" data-reveal>
      <p class="demo__eyebrow">See It in Action</p>
      <h2>AI governance should not rely on&nbsp;guesswork.</h2>
      <p class="demo__description">In this short demonstration, we show how SorticAI structures standards and regulatory analysis, coordinates specialized AI agents, and produces a clear compliance assessment in&nbsp;minutes.</p>
    </div>

    <div class="demo__player-wrap" data-reveal style="transition-delay: 150ms;">
      <div class="demo__player" id="demo-player">
        <video
          id="demo-video"
          class="demo__video"
          preload="none"
          playsinline
          controls
        >
          <source src="/demo.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>

        <button class="demo__play-overlay" id="demo-play-btn" aria-label="Play demo video">
          <div class="demo__play-icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="32" cy="32" r="31" stroke="currentColor" stroke-width="2" />
              <polygon points="26,20 26,44 46,32" fill="currentColor" />
            </svg>
          </div>
          <span class="demo__play-label">Watch the demo</span>
        </button>

        <div class="demo__poster" id="demo-poster" aria-hidden="true">
          <div class="demo__poster-grid">
            <div class="demo__poster-node" style="--x: 15%; --y: 25%;"></div>
            <div class="demo__poster-node" style="--x: 35%; --y: 18%;"></div>
            <div class="demo__poster-node" style="--x: 55%; --y: 30%;"></div>
            <div class="demo__poster-node" style="--x: 75%; --y: 22%;"></div>
            <div class="demo__poster-node demo__poster-node--center" style="--x: 50%; --y: 50%;"></div>
            <div class="demo__poster-node" style="--x: 25%; --y: 55%;"></div>
            <div class="demo__poster-node" style="--x: 45%; --y: 70%;"></div>
            <div class="demo__poster-node" style="--x: 70%; --y: 65%;"></div>
            <div class="demo__poster-node" style="--x: 85%; --y: 45%;"></div>

            <svg class="demo__poster-lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
              <line x1="15" y1="25" x2="35" y2="18" />
              <line x1="35" y1="18" x2="55" y2="30" />
              <line x1="55" y1="30" x2="75" y2="22" />
              <line x1="50" y1="50" x2="15" y2="25" />
              <line x1="50" y1="50" x2="35" y2="18" />
              <line x1="50" y1="50" x2="55" y2="30" />
              <line x1="50" y1="50" x2="75" y2="22" />
              <line x1="50" y1="50" x2="25" y2="55" />
              <line x1="50" y1="50" x2="45" y2="70" />
              <line x1="50" y1="50" x2="70" y2="65" />
              <line x1="50" y1="50" x2="85" y2="45" />
              <line x1="25" y1="55" x2="45" y2="70" />
              <line x1="45" y1="70" x2="70" y2="65" />
              <line x1="70" y1="65" x2="85" y2="45" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <p class="demo__footnote" data-reveal style="transition-delay: 300ms;">Watch how complex legal, standards and regulatory workflows become structured&nbsp;oversight.</p>
  </div>
</section>

<style>
  .demo {
    background-color: var(--color-primary);
    color: rgba(255, 255, 255, 0.85);
    overflow: hidden;
    position: relative;
  }

  .demo::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.4;
    pointer-events: none;
  }

  .demo__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--s-7);
  }

  .demo__eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
    margin-bottom: var(--s-3);
  }

  .demo__header h2 {
    color: var(--color-white);
    margin-bottom: var(--s-4);
  }

  .demo__description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0;
  }

  /* --- Video Player --- */
  .demo__player-wrap {
    max-width: 960px;
    margin: 0 auto;
    position: relative;
  }

  .demo__player {
    position: relative;
    aspect-ratio: 64 / 53;
    border-radius: 12px;
    overflow: hidden;
    background: #0d1b2e;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .demo__video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  /* Hide native controls until playing */
  .demo__video:not([data-playing]) {
    pointer-events: none;
  }

  .demo__video[data-playing] {
    pointer-events: auto;
  }

  /* --- Play Overlay --- */
  .demo__play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--s-4);
    z-index: 3;
    cursor: pointer;
    background: transparent;
    transition: var(--transition);
  }

  .demo__play-overlay:hover .demo__play-icon {
    transform: scale(1.1);
  }

  .demo__play-overlay:hover .demo__play-icon svg circle {
    stroke-width: 2.5;
  }

  .demo__play-overlay[hidden] {
    display: none;
  }

  .demo__play-icon {
    width: 80px;
    height: 80px;
    color: var(--color-white);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.3));
  }

  .demo__play-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.02em;
  }

  /* --- Poster (placeholder graphic) --- */
  .demo__poster {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(135deg, #0d1b2e 0%, #17324d 50%, #0d1b2e 100%);
    pointer-events: none;
  }

  .demo__poster[hidden] {
    display: none;
  }

  .demo__poster-grid {
    position: absolute;
    inset: 0;
  }

  .demo__poster-node {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 8px;
    height: 8px;
    background: var(--color-secondary);
    border-radius: 50%;
    opacity: 0.5;
    transform: translate(-50%, -50%);
    animation: demo-pulse 3s ease-in-out infinite;
  }

  .demo__poster-node--center {
    width: 16px;
    height: 16px;
    opacity: 0.8;
    box-shadow: 0 0 20px rgba(122, 191, 81, 0.3);
  }

  .demo__poster-node:nth-child(2) { animation-delay: 0.4s; }
  .demo__poster-node:nth-child(3) { animation-delay: 0.8s; }
  .demo__poster-node:nth-child(4) { animation-delay: 1.2s; }
  .demo__poster-node:nth-child(6) { animation-delay: 0.6s; }
  .demo__poster-node:nth-child(7) { animation-delay: 1.0s; }
  .demo__poster-node:nth-child(8) { animation-delay: 1.4s; }
  .demo__poster-node:nth-child(9) { animation-delay: 0.2s; }

  .demo__poster-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .demo__poster-lines line {
    stroke: rgba(122, 191, 81, 0.12);
    stroke-width: 0.3;
  }

  @keyframes demo-pulse {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.7; transform: translate(-50%, -50%) scale(1.3); }
  }

  /* --- Footnote --- */
  .demo__footnote {
    text-align: center;
    margin-top: var(--s-6);
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.55);
    font-style: italic;
    margin-bottom: 0;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .demo__play-icon {
      width: 64px;
      height: 64px;
    }

    .demo__play-label {
      font-size: 0.8125rem;
    }

    .demo__player {
      border-radius: 8px;
    }
  }

  @media (max-width: 480px) {
    .demo__play-icon {
      width: 52px;
      height: 52px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .demo__poster-node {
      animation: none;
      opacity: 0.5;
    }
  }
</style>

<script>
  const playBtn = document.getElementById('demo-play-btn');
  const video = document.getElementById('demo-video') as HTMLVideoElement;
  const poster = document.getElementById('demo-poster');

  if (playBtn && video && poster) {
    playBtn.addEventListener('click', () => {
      poster.hidden = true;
      playBtn.hidden = true;
      video.setAttribute('data-playing', '');
      video.play();
    });

    video.addEventListener('ended', () => {
      poster.hidden = false;
      playBtn.hidden = false;
      video.removeAttribute('data-playing');
    });

    video.addEventListener('pause', () => {
      if (video.ended) return;
      // Keep controls visible when paused mid-play
    });
  }
</script>
