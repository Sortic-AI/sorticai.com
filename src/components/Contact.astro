---
import { Icon } from 'astro-icon/components';
---

<section class="contact section-padding" id="contact">
  <div class="container">
    <div class="contact__grid" data-reveal>
      <div class="contact__info">
        <h2>Request a Confidential AI Regulatory Briefing</h2>
        <p class="contact__body">AI governance is no longer optional. Clarity is achievable.</p>
        <p class="contact__body">To schedule your 48-Hour AI Compliance Health-Check or discuss ongoing Reg-Radar oversight, speak directly with a SorticAI advisor.</p>

        <div class="contact__icons">
          <div class="contact__icon-item">
            <div class="contact__icon-circle">
              <Icon name="lucide:mail" size={20} />
            </div>
            <span>Direct Communication</span>
          </div>
          <div class="contact__icon-item">
            <div class="contact__icon-circle">
              <Icon name="lucide:shield-check" size={20} />
            </div>
            <span>Confidential & Secure</span>
          </div>
          <div class="contact__icon-item">
            <div class="contact__icon-circle">
              <Icon name="lucide:clock" size={20} />
            </div>
            <span>48-Hour Turnaround</span>
          </div>
        </div>
      </div>

      <form class="contact__form" id="contact-form">
        <input type="hidden" name="apiKey" value="sf_g4afac550hb62a3883cf5069" />
        <input type="hidden" name="subject" value="New briefing request from SorticAI" />
        <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
          <label for="honeypot">Leave this empty</label>
          <input type="text" id="honeypot" name="honeypot" tabindex="-1" autocomplete="off" />
        </div>

        <div class="contact__field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>

        <div class="contact__field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>

        <div class="contact__field">
          <label for="company">Company</label>
          <input type="text" id="company" name="company" autocomplete="organization" />
        </div>

        <div class="contact__field">
          <label for="role">Your Role</label>
          <input type="text" id="role" name="role" autocomplete="organization-title" />
        </div>

        <div class="contact__field">
          <label for="message">How can we assist you?</label>
          <textarea id="message" name="message" rows="4"></textarea>
        </div>

        <button type="submit" class="btn btn-primary contact__submit" id="contact-submit">
          Request Briefing
          <Icon name="lucide:arrow-right" size={18} />
        </button>

        <div class="contact__message contact__message--success" id="contact-success" hidden>
          <div class="contact__message-icon">
            <Icon name="lucide:check-circle" size={20} />
          </div>
          <p>Your request has been sent successfully. We'll be in touch within 48 hours.</p>
        </div>

        <div class="contact__message contact__message--error" id="contact-error" hidden>
          <div class="contact__message-icon">
            <Icon name="lucide:alert-circle" size={20} />
          </div>
          <p>Something went wrong. Please try again or email us directly.</p>
        </div>

        <p class="contact__privacy">By submitting this form, you provide contact information used solely to communicate with you regarding SorticAI services. We handle all personal data in accordance with applicable data protection laws and our internal privacy policies. You may exercise your data rights at any time by contacting our privacy team.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-white);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-7);
    align-items: start;
  }

  .contact__info h2 {
    margin-bottom: var(--s-4);
  }

  .contact__body {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .contact__icons {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-top: var(--s-5);
  }

  .contact__icon-item {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .contact__icon-circle {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(122, 191, 81, 0.1);
    color: var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact__icon-item span {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }

  /* Form */
  .contact__form {
    background: var(--color-bg-light);
    padding: var(--s-5);
    border-radius: 12px;
  }

  .contact__field {
    margin-bottom: var(--s-3);
  }

  .contact__field label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--s-1);
  }

  .contact__field input,
  .contact__field textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-white);
    color: var(--color-text);
    font-size: 0.9375rem;
    transition: var(--transition);
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    outline: none;
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 3px rgba(122, 191, 81, 0.15);
  }

  .contact__field textarea {
    resize: vertical;
    min-height: 100px;
  }

  .contact__submit {
    width: 100%;
    margin-top: var(--s-2);
  }

  .contact__privacy {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-top: var(--s-3);
  }

  .contact__message[hidden] {
    display: none;
  }

  .contact__message {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    padding: var(--s-3) var(--s-4);
    border-radius: 8px;
    margin-top: var(--s-3);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .contact__message p {
    margin: 0;
  }

  .contact__message-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact__message--success {
    background: rgba(122, 191, 81, 0.1);
    color: #2d6a0e;
  }

  .contact__message--success .contact__message-icon {
    background: rgba(122, 191, 81, 0.2);
    color: var(--color-secondary);
  }

  .contact__message--error {
    background: rgba(220, 53, 53, 0.1);
    color: #991b1b;
  }

  .contact__message--error .contact__message-icon {
    background: rgba(220, 53, 53, 0.2);
    color: #dc3535;
  }

  .contact__submit--loading {
    opacity: 0.7;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 767px) {
    .contact__form {
      order: -1;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
  const successMsg = document.getElementById('contact-success') as HTMLElement;
  const errorMsg = document.getElementById('contact-error') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    // Honeypot check — silently pretend success
    if (formData.get('honeypot')) {
      form.querySelectorAll<HTMLElement>('.contact__field').forEach(f => f.hidden = true);
      submitBtn.hidden = true;
      successMsg.hidden = false;
      return;
    }

    // Loading state
    const originalHTML = submitBtn.innerHTML;
    submitBtn.classList.add('contact__submit--loading');
    submitBtn.textContent = 'Sending...';

    errorMsg.hidden = true;

    try {
      const res = await fetch('https://api.staticforms.dev/submit', {
        method: 'POST',
        body: formData,
      });

      const result = await res.json();

      if (result.success) {
        form.querySelectorAll<HTMLElement>('.contact__field').forEach(f => f.hidden = true);
        submitBtn.hidden = true;
        form.reset();
        successMsg.hidden = false;
      } else {
        errorMsg.hidden = false;
        submitBtn.classList.remove('contact__submit--loading');
        submitBtn.innerHTML = originalHTML;
      }
    } catch {
      errorMsg.hidden = false;
      submitBtn.classList.remove('contact__submit--loading');
      submitBtn.innerHTML = originalHTML;
    }
  });
</script>
